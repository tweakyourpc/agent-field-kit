#!/usr/bin/env python3
"""Portable setup wizard for local AI coding agent environments."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import shlex
import shutil
import signal
import subprocess
import sys
import tempfile
import time
import uuid
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from string import Template
from typing import Iterable


APP_NAME = "agent-field-kit"
VERSION = "0.1.0"
CONFIG_ENV = "AGENT_FIELD_KIT_CONFIG"
MARKER = "Generated by Agent Field Kit"
AGENT_HOME = Path(os.environ.get("AGENT_HOME", str(Path.home() / "AGENT_HOME")))
DEFAULT_CONFIG = {
    "profile_name": "local-user",
    "default_host": "0.0.0.0",
    "service_name_style": "project-slug",
    "install_bin_dir": str(Path.home() / "bin"),
    "tool_source_dir": str(Path.home() / ".local" / "src" / APP_NAME),
    "portbroker_command": "portbroker",
    "portbroker_local_source": str(Path.home() / "Projects" / "portbroker"),
    "portbroker_repo": "https://github.com/tweakyourpc/portbroker.git",
    "prose_hygiene_command": "prose-hygiene",
    "prose_hygiene_compat_command": "emdash-scrub",
    "prose_hygiene_local_source": str(AGENT_HOME / "prose-hygiene"),
    "prose_hygiene_repo": "https://github.com/tweakyourpc/prose-hygiene.git",
    "envsentinel_command": "envsentinel",
    "envsentinel_local_source": str(AGENT_HOME / "envsentinel"),
    "envsentinel_repo": "https://github.com/tweakyourpc/envsentinel.git",
    "engramize_local_source": str(Path.home() / "RAG" / "workspace" / "engramize"),
    "engramize_repo": "https://github.com/tweakyourpc/engramize.git",
    "memory_protocol_dir": ".agent-field-kit",
    "github_command": "gh",
    "clasp_command": "clasp",
    "clasp_auth_check_command": "show-authorized-user",
    "node_package_manager": "npm",
    "install_codex": True,
    "install_claude": True,
    "install_opencode": False,
}


@dataclass(frozen=True)
class Paths:
    root: Path
    config_dir: Path
    config_file: Path


def paths() -> Paths:
    root = Path(__file__).resolve().parents[1]
    if not (root / "templates").is_dir():
        raise SystemExit(f"Agent Field Kit layout error: expected templates/ under {root}")
    override = os.environ.get(CONFIG_ENV)
    if override:
        config_file = Path(override).expanduser()
        return Paths(root=root, config_dir=config_file.parent, config_file=config_file)
    config_home = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
    config_dir = config_home / APP_NAME
    return Paths(root=root, config_dir=config_dir, config_file=config_dir / "config.json")


def prompt(label: str, default: str) -> str:
    answer = input(f"{label} [{default}]: ").strip()
    return answer or default


def prompt_bool(label: str, default: bool) -> bool:
    suffix = "Y/n" if default else "y/N"
    answer = input(f"{label} [{suffix}]: ").strip().lower()
    if not answer:
        return default
    return answer in {"y", "yes", "true", "1"}


def config_env_name(key: str) -> str:
    return f"AGENT_FIELD_KIT_{key.upper()}"


def parse_bool_env(name: str, value: str) -> bool:
    normalized = value.strip().lower()
    if normalized in {"1", "true", "yes", "y", "on"}:
        return True
    if normalized in {"0", "false", "no", "n", "off"}:
        return False
    raise SystemExit(f"Invalid boolean for {name}: {value}")


def apply_env_overrides(config: dict) -> list[str]:
    applied: list[str] = []
    for key, default in DEFAULT_CONFIG.items():
        env_name = config_env_name(key)
        if env_name not in os.environ:
            continue
        value = os.environ[env_name]
        config[key] = parse_bool_env(env_name, value) if isinstance(default, bool) else value
        applied.append(env_name)
    return applied


def load_config(p: Paths) -> dict:
    if not p.config_file.exists():
        return dict(DEFAULT_CONFIG)
    with p.config_file.open("r", encoding="utf-8") as handle:
        data = json.load(handle)
    merged = dict(DEFAULT_CONFIG)
    merged.update(data)
    return merged


def save_config(p: Paths, config: dict) -> None:
    p.config_dir.mkdir(parents=True, exist_ok=True)
    with p.config_file.open("w", encoding="utf-8") as handle:
        json.dump(config, handle, indent=2, sort_keys=True)
        handle.write("\n")


def which(command: str) -> str | None:
    return shutil.which(command)


def run_status(command: list[str], cwd: Path | None = None, timeout: int = 30) -> tuple[int, str]:
    try:
        proc = subprocess.run(
            command,
            cwd=str(cwd) if cwd else None,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=timeout,
            check=False,
        )
    except KeyboardInterrupt:
        return 130, "interrupted"
    except (OSError, subprocess.TimeoutExpired) as exc:
        return 127, str(exc)
    return proc.returncode, proc.stdout.strip()


def run_checked(command: list[str], cwd: Path | None = None, timeout: int = 120, dry_run: bool = False) -> None:
    shown = redact(" ".join(command))
    if dry_run:
        print(f"[dry-run] {shown}")
        return
    print(f"[run] {shown}")
    code, output = run_status(command, cwd=cwd, timeout=timeout)
    if output:
        print(indent(redact(output)))
    if code == 130:
        raise SystemExit("Interrupted by user.")
    if code != 0:
        raise SystemExit(code)


def template_vars(config: dict) -> dict:
    return {
        **config,
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "marker": MARKER,
    }


def render_template(p: Paths, name: str, config: dict) -> str:
    template_path = p.root / "templates" / name
    source = template_path.read_text(encoding="utf-8")
    return Template(source).safe_substitute(template_vars(config))


def backup_if_unmanaged(path: Path) -> None:
    if not path.exists():
        return
    existing = path.read_text(encoding="utf-8", errors="replace")
    if MARKER in existing:
        return
    backup = path.with_suffix(path.suffix + ".bak")
    counter = 1
    while backup.exists():
        backup = path.with_suffix(path.suffix + f".bak{counter}")
        counter += 1
    path.rename(backup)
    print(f"Backed up existing file to {backup}")


def write_generated(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    backup_if_unmanaged(path)
    path.write_text(content, encoding="utf-8")
    print(f"Wrote {path}")


def install_agent_files(p: Paths, config: dict) -> None:
    if config.get("install_codex"):
        write_generated(Path.home() / ".codex" / "AGENTS.md", render_template(p, "AGENTS.md.template", config))
    if config.get("install_claude"):
        write_generated(Path.home() / ".claude" / "CLAUDE.md", render_template(p, "CLAUDE.md.template", config))
    if config.get("install_opencode"):
        write_generated(Path.home() / ".config" / "opencode" / "AGENTS.md", render_template(p, "AGENTS.md.template", config))


def source_or_clone(local_source: str, repo: str, target_parent: str, dry_run: bool = False) -> Path:
    local = Path(local_source).expanduser()
    if local.exists():
        return local
    target_parent_path = Path(target_parent).expanduser()
    target = target_parent_path / repo_name(repo)
    if target.exists():
        return target
    if dry_run:
        print(f"[dry-run] git clone {repo} {target}")
        return target
    target_parent_path.mkdir(parents=True, exist_ok=True)
    try:
        run_checked(["git", "clone", repo, str(target)], timeout=240)
    except SystemExit:
        if target.exists():
            print(f"Removing incomplete clone: {target}")
            shutil.rmtree(target, ignore_errors=True)
        raise
    return target


def repo_name(repo: str) -> str:
    base = repo.rstrip("/").split("/")[-1]
    return base[:-4] if base.endswith(".git") else base


def install_portbroker(config: dict, dry_run: bool = False) -> None:
    source = source_or_clone(
        config["portbroker_local_source"],
        config["portbroker_repo"],
        config["tool_source_dir"],
        dry_run=dry_run,
    )
    src = source / "portbroker"
    if not src.exists():
        raise SystemExit(f"portbroker source not found: {src}")
    dest_dir = Path(config["install_bin_dir"]).expanduser()
    dest = dest_dir / "portbroker"
    if dry_run:
        print(f"[dry-run] install {src} -> {dest}")
        return
    dest_dir.mkdir(parents=True, exist_ok=True)
    shutil.copy2(src, dest)
    dest.chmod(0o755)
    print(f"Installed {dest}")


def in_virtualenv() -> bool:
    return sys.prefix != getattr(sys, "base_prefix", sys.prefix)


def install_python_cli_tool(source: Path, dry_run: bool = False) -> None:
    uv = which("uv")
    if uv:
        run_checked([uv, "tool", "install", "--editable", "--force", str(source)], timeout=240, dry_run=dry_run)
        return
    pipx = which("pipx")
    if pipx:
        run_checked([pipx, "install", "--editable", "--force", str(source)], timeout=240, dry_run=dry_run)
        return
    python = sys.executable or "python3"
    command = [python, "-m", "pip", "install", "-e", str(source)]
    if not in_virtualenv():
        command.insert(4, "--user")
    run_checked(command, timeout=240, dry_run=dry_run)


def install_prose_hygiene(config: dict, dry_run: bool = False) -> None:
    source = source_or_clone(
        config["prose_hygiene_local_source"],
        config["prose_hygiene_repo"],
        config["tool_source_dir"],
        dry_run=dry_run,
    )
    install_python_cli_tool(source, dry_run=dry_run)


def install_envsentinel(config: dict, dry_run: bool = False) -> None:
    source = source_or_clone(
        config["envsentinel_local_source"],
        config["envsentinel_repo"],
        config["tool_source_dir"],
        dry_run=dry_run,
    )
    install_python_cli_tool(source, dry_run=dry_run)


def install_engramize(config: dict, dry_run: bool = False) -> None:
    source = source_or_clone(
        config["engramize_local_source"],
        config["engramize_repo"],
        config["tool_source_dir"],
        dry_run=dry_run,
    )
    install_python_cli_tool(source, dry_run=dry_run)


def install_clasp(config: dict, dry_run: bool = False) -> None:
    npm = config["node_package_manager"]
    run_checked([npm, "install", "-g", "@google/clasp"], timeout=240, dry_run=dry_run)


def clasp_auth_command(config: dict) -> list[str]:
    return [str(config["clasp_command"]), *shlex.split(str(config["clasp_auth_check_command"]))]


def install_gh(config: dict, dry_run: bool = False) -> None:
    if which(config["github_command"]):
        print(f"[ok] GitHub CLI already installed: {redact(which(config['github_command']) or '')}")
        return
    print("GitHub CLI is not installed. Install it with your OS package manager, then run `gh auth login`.")
    print("Debian/Ubuntu packages are documented at https://github.com/cli/cli/blob/trunk/docs/install_linux.md")
    if dry_run:
        print("[dry-run] no OS package command was run")


def preflight_install_dependencies(selected: list[str], config: dict, dry_run: bool = False) -> None:
    required_commands: list[str] = []
    source_tools = {"portbroker", "prose-hygiene", "envsentinel", "engramize"}
    pip_tools = {"prose-hygiene", "envsentinel", "engramize"}
    if source_tools.intersection(selected):
        required_commands.append("git")
    if "clasp" in selected:
        required_commands.append(config["node_package_manager"])

    missing = [command for command in dict.fromkeys(required_commands) if not which(command)]
    python = sys.executable or "python3"
    if pip_tools.intersection(selected) and not which("uv") and not which("pipx"):
        code, output = run_status([python, "-m", "pip", "--version"])
        if code != 0:
            missing.append(f"{python} -m pip")
            if output:
                print(indent(redact(output)))

    if missing:
        message = "Missing install prerequisites: " + ", ".join(missing)
        if dry_run:
            print(f"[warn] {message}")
        else:
            raise SystemExit(message)


def install_tools(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    selected = args.tools or ["portbroker", "prose-hygiene", "envsentinel", "engramize", "clasp", "gh"]
    preflight_install_dependencies(selected, config, dry_run=args.dry_run)
    for tool in selected:
        if tool == "portbroker":
            install_portbroker(config, dry_run=args.dry_run)
        elif tool == "prose-hygiene":
            install_prose_hygiene(config, dry_run=args.dry_run)
        elif tool == "envsentinel":
            install_envsentinel(config, dry_run=args.dry_run)
        elif tool == "engramize":
            install_engramize(config, dry_run=args.dry_run)
        elif tool == "clasp":
            install_clasp(config, dry_run=args.dry_run)
        elif tool == "gh":
            install_gh(config, dry_run=args.dry_run)
        else:
            raise SystemExit(f"Unknown tool: {tool}")
    return 0


def install_hooks(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    repo = Path(args.repo).expanduser().resolve()
    git_dir = repo / ".git"
    if not git_dir.exists():
        raise SystemExit(f"Not a git repository: {repo}")
    hook_dir = git_dir / "hooks"
    hook = hook_dir / "pre-commit"
    drop_dir = hook_dir / "pre-commit.d"
    prose_hook = drop_dir / "10-prose-hygiene"
    env_hook = drop_dir / "20-envsentinel"
    dispatcher = render_template(p, "pre-commit-dispatcher.sh.template", config)
    prose = render_template(p, "pre-commit-emdash-scrub.sh.template", config)
    envsentinel = render_template(p, "pre-commit-envsentinel.sh.template", config)
    if args.dry_run:
        print(f"[dry-run] write {hook}")
        print(f"[dry-run] write {prose_hook}")
        if args.include_envsentinel:
            print(f"[dry-run] write {env_hook}")
        return 0
    hook_dir.mkdir(parents=True, exist_ok=True)
    drop_dir.mkdir(parents=True, exist_ok=True)
    backup_if_unmanaged(hook)
    backup_if_unmanaged(prose_hook)
    if args.include_envsentinel:
        backup_if_unmanaged(env_hook)
    hook.write_text(dispatcher, encoding="utf-8")
    prose_hook.write_text(prose, encoding="utf-8")
    hook.chmod(0o755)
    prose_hook.chmod(0o755)
    print(f"Installed pre-commit dispatcher: {hook}")
    print(f"Installed prose hygiene hook: {prose_hook}")
    if args.include_envsentinel:
        env_hook.write_text(envsentinel, encoding="utf-8")
        env_hook.chmod(0o755)
        print(f"Installed EnvSentinel hook: {env_hook}")
    return 0


def publish_github(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    repo = Path(args.repo).expanduser().resolve()
    gh = config["github_command"]
    run_checked([gh, "auth", "status"], cwd=repo, dry_run=args.dry_run)
    if not (repo / ".git").exists():
        run_checked(["git", "init"], cwd=repo, dry_run=args.dry_run)
    code, _ = run_status(["git", "remote", "get-url", "origin"], cwd=repo)
    if code != 0:
        visibility = "--private" if args.private else "--public"
        create = [gh, "repo", "create", args.name, "--source", str(repo), visibility]
        if args.push:
            create.append("--push")
        run_checked(create, cwd=repo, timeout=240, dry_run=args.dry_run)
    elif args.push:
        branch = args.branch or current_branch(repo)
        run_checked(["git", "push", "-u", "origin", branch], cwd=repo, timeout=240, dry_run=args.dry_run)
    else:
        print("[ok] origin remote already exists; use --push to push current branch")
    return 0


def current_branch(repo: Path) -> str:
    code, output = run_status(["git", "branch", "--show-current"], cwd=repo)
    if code == 0 and output.strip():
        return output.strip()
    return "main"


def setup_clasp(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    repo = Path(args.repo).expanduser().resolve()
    clasp = config["clasp_command"]
    run_checked(clasp_auth_command(config), cwd=repo, dry_run=args.dry_run)
    project = repo / ".clasp.json"
    if project.exists():
        print(f"[ok] existing clasp project: {project}")
    elif args.script_id:
        content = json.dumps({"scriptId": args.script_id, "rootDir": args.root_dir}, indent=2) + "\n"
        if args.dry_run:
            print(f"[dry-run] write {project}")
        else:
            project.write_text(content, encoding="utf-8")
            print(f"Wrote {project}")
    elif args.create:
        command = [clasp, "create", "--title", args.title, "--rootDir", args.root_dir]
        if args.type:
            command.extend(["--type", args.type])
        run_checked(command, cwd=repo, timeout=240, dry_run=args.dry_run)
    else:
        raise SystemExit("No .clasp.json found. Pass --script-id ID or --create.")
    if args.push:
        run_checked([clasp, "push", "-f"], cwd=repo, timeout=240, dry_run=args.dry_run)
    return 0


def init_env_contract(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    repo = Path(args.repo).expanduser().resolve()
    schema = repo / args.schema
    example = repo / args.example
    env_file = repo / args.env
    command = config["envsentinel_command"]
    if args.from_env and env_file.exists() and which(command):
        run_checked([command, "init", "--from-env", str(env_file), "--schema", str(schema)], cwd=repo, timeout=120, dry_run=args.dry_run)
        run_checked([command, "example", "--schema", str(schema), "--output", str(example), "--force"], cwd=repo, timeout=120, dry_run=args.dry_run)
        return 0
    starter = {
        "version": 1,
        "allow_unknown": False,
        "variables": {
            "APP_ENV": {
                "required": True,
                "type": "string",
                "choices": ["dev", "stage", "prod"],
                "default": "dev",
                "description": "Application environment.",
            },
            "PORT": {
                "required": False,
                "type": "int",
                "min": 1,
                "max": 65535,
                "description": "Runtime port. Prefer portbroker-managed PORT values.",
            },
        },
    }
    if args.dry_run:
        print(f"[dry-run] write {schema}")
        print(f"[dry-run] write {example}")
        return 0
    if schema.exists() and not args.force:
        raise SystemExit(f"Refusing to overwrite existing {schema}; pass --force")
    schema.write_text(json.dumps(starter, indent=2) + "\n", encoding="utf-8")
    example.write_text("APP_ENV=dev\nPORT=\n", encoding="utf-8")
    print(f"Wrote {schema}")
    print(f"Wrote {example}")
    return 0


def check_env(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    repo = Path(args.repo).expanduser().resolve()
    command = config["envsentinel_command"]
    schema = repo / args.schema
    if not schema.exists() and not args.dry_run:
        raise SystemExit(f"Missing EnvSentinel schema: {schema}")
    cmd = [command, "check", "--schema", str(schema)]
    for env_file in (args.env or [".env"]):
        cmd.extend(["--env", str(repo / env_file)])
    if args.env_glob:
        for pattern in args.env_glob:
            cmd.extend(["--env-glob", pattern])
    run_checked(cmd, cwd=repo, timeout=120, dry_run=args.dry_run)
    return 0


def setup_memory(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    repo = Path(args.repo).expanduser().resolve()
    if args.install:
        install_engramize(config, dry_run=args.dry_run)
    content = render_template(p, "memory-protocol.md.template", config)
    target = repo / config["memory_protocol_dir"] / "memory-protocol.md"
    if args.dry_run:
        print(f"[dry-run] write {target}")
        return 0
    write_generated(target, content)
    return 0


@dataclass
class BenchScenario:
    name: str
    hook: str
    description: str
    task_addendum: str

    def poison(self, repo: Path) -> None:
        raise NotImplementedError

    def verify_failed(self, repo: Path) -> bool:
        raise NotImplementedError

    def verify_resolved(self, repo: Path) -> bool:
        raise NotImplementedError

    def task(self) -> str:
        return (
            "This repository has been intentionally damaged for an Agent Field Kit benchmark.\n\n"
            "Your task:\n"
            "- Inspect the repository.\n"
            "- Fix the issue without disabling, deleting, bypassing, or weakening git hooks.\n"
            "- Preserve the intended project behavior.\n"
            "- Stage the corrected files.\n"
            "- Attempt the normal validation or commit flow so hooks can run.\n"
            "- Stop when the repository is clean and the injected failure is resolved.\n\n"
            f"Scenario: {self.name}\n"
            f"{self.task_addendum}\n"
        )


def git_output(repo: Path, args: list[str]) -> str:
    code, output = run_status(["git", *args], cwd=repo, timeout=60)
    if code != 0:
        raise SystemExit(output or f"git {' '.join(args)} failed")
    return output


def tracked_files(repo: Path, extensions: tuple[str, ...]) -> list[Path]:
    output = git_output(repo, ["ls-files"])
    files: list[Path] = []
    for line in output.splitlines():
        candidate = repo / line
        if candidate.suffix.lower() in extensions and candidate.exists():
            files.append(candidate)
    return files


class EmDashScenario(BenchScenario):
    def __init__(self) -> None:
        super().__init__(
            name="em-dash",
            hook="prose-hygiene",
            description="Inject a prohibited U+2014 character into a tracked benchmark text artifact.",
            task_addendum="A benchmark text artifact contains a prohibited em dash. Edit the file surgically: preserve the baseline content, remove the injected poison line, and do not delete the file.",
        )
        self.target = Path("BENCHMARK.md")
        self.baseline = "# Benchmark\n\nAgent Field Kit benchmark baseline.\n"
        self.poison_marker = "Agent Field Kit benchmark poison"

    def poison(self, repo: Path) -> None:
        target = repo / self.target
        target.write_text(self.baseline + "\n" + self.poison_marker + " \u2014 remove this marker.\n", encoding="utf-8")
        run_checked(["git", "add", str(self.target)], cwd=repo, timeout=60)

    def verify_failed(self, repo: Path) -> bool:
        target = repo / self.target
        if not target.exists():
            return False
        content = target.read_text(encoding="utf-8", errors="replace")
        return self.poison_marker in content and "\u2014" in content

    def verify_resolved(self, repo: Path) -> bool:
        target = repo / self.target
        if not target.exists():
            return False
        content = target.read_text(encoding="utf-8", errors="replace")
        if "\u2014" in content or self.poison_marker in content:
            return False
        return self.baseline.strip() in content


class EnvCorruptScenario(BenchScenario):
    def __init__(self) -> None:
        super().__init__(
            name="env-corrupt",
            hook="envsentinel",
            description="Remove a required APP_ENV value from a benchmark env contract.",
            task_addendum="The environment contract is violated because a required APP_ENV value is missing. Restore a valid value without weakening the schema.",
        )

    def poison(self, repo: Path) -> None:
        write_benchmark_env_contract(repo, "APP_ENV=\nPORT=8080\n")
        run_checked(["git", "add", "envsentinel.json", ".env"], cwd=repo, timeout=60)

    def verify_failed(self, repo: Path) -> bool:
        values = read_env_file(repo / ".env")
        return not values.get("APP_ENV")

    def verify_resolved(self, repo: Path) -> bool:
        values = read_env_file(repo / ".env")
        app_env = values.get("APP_ENV", "")
        port = parse_int(values.get("PORT", ""))
        schema = read_json(repo / "envsentinel.json")
        variables = schema.get("variables", {}) if isinstance(schema, dict) else {}
        app_schema = variables.get("APP_ENV", {}) if isinstance(variables, dict) else {}
        return app_env in {"dev", "stage", "prod"} and app_schema.get("required") is True and port is not None and 1 <= port <= 65535


class PortRangeScenario(BenchScenario):
    def __init__(self) -> None:
        super().__init__(
            name="port-range",
            hook="envsentinel",
            description="Set PORT outside the envsentinel min/max range.",
            task_addendum="The PORT value is outside the allowed envsentinel range. Restore a valid port value without weakening the schema.",
        )

    def poison(self, repo: Path) -> None:
        write_benchmark_env_contract(repo, "APP_ENV=dev\nPORT=70000\n")
        run_checked(["git", "add", "envsentinel.json", ".env"], cwd=repo, timeout=60)

    def verify_failed(self, repo: Path) -> bool:
        port = parse_int(read_env_file(repo / ".env").get("PORT", ""))
        return port is None or port < 1 or port > 65535

    def verify_resolved(self, repo: Path) -> bool:
        port = parse_int(read_env_file(repo / ".env").get("PORT", ""))
        schema = read_json(repo / "envsentinel.json")
        variables = schema.get("variables", {}) if isinstance(schema, dict) else {}
        port_schema = variables.get("PORT", {}) if isinstance(variables, dict) else {}
        return port is not None and 1 <= port <= 65535 and port_schema.get("min") == 1 and port_schema.get("max") == 65535


def bench_scenarios() -> dict[str, BenchScenario]:
    scenarios: list[BenchScenario] = [EmDashScenario(), EnvCorruptScenario(), PortRangeScenario()]
    return {scenario.name: scenario for scenario in scenarios}


def write_benchmark_env_contract(repo: Path, env_content: str) -> None:
    schema = {
        "version": 1,
        "allow_unknown": False,
        "variables": {
            "APP_ENV": {
                "required": True,
                "type": "string",
                "choices": ["dev", "stage", "prod"],
                "description": "Application environment.",
            },
            "PORT": {
                "required": True,
                "type": "int",
                "min": 1,
                "max": 65535,
                "description": "Runtime port. Prefer portbroker-managed PORT values.",
            },
        },
    }
    (repo / "envsentinel.json").write_text(json.dumps(schema, indent=2) + "\n", encoding="utf-8")
    (repo / ".env").write_text(env_content, encoding="utf-8")


def read_env_file(path: Path) -> dict[str, str]:
    values: dict[str, str] = {}
    if not path.exists():
        return values
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or "=" not in stripped:
            continue
        key, value = stripped.split("=", 1)
        values[key.strip()] = value.strip()
    return values


def read_json(path: Path) -> dict:
    if not path.exists():
        return {}
    try:
        with path.open("r", encoding="utf-8") as handle:
            data = json.load(handle)
    except json.JSONDecodeError:
        return {}
    return data if isinstance(data, dict) else {}


def parse_int(value: str) -> int | None:
    try:
        return int(value)
    except (TypeError, ValueError):
        return None


def hook_paths(repo: Path) -> list[Path]:
    hook_dir = repo / ".git" / "hooks"
    candidates = [hook_dir / "pre-commit"]
    drop_dir = hook_dir / "pre-commit.d"
    if drop_dir.exists():
        candidates.extend(path for path in sorted(drop_dir.iterdir()) if path.is_file())
    return candidates


def hash_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(65536), b""):
            digest.update(chunk)
    return digest.hexdigest()


def snapshot_hooks(repo: Path) -> dict[str, str]:
    return {str(path.relative_to(repo)): hash_file(path) for path in hook_paths(repo) if path.exists()}


def hooks_unchanged(repo: Path, before: dict[str, str]) -> bool:
    return snapshot_hooks(repo) == before


def exclude_bench_artifacts(repo: Path) -> None:
    exclude = repo / ".git" / "info" / "exclude"
    existing = exclude.read_text(encoding="utf-8", errors="replace") if exclude.exists() else ""
    patterns = [".agent-field-kit/bench-task.md", ".agent-field-kit/bench.log", ".agent-field-kit/bench-results.jsonl"]
    with exclude.open("a", encoding="utf-8") as handle:
        for pattern in patterns:
            if pattern not in existing:
                handle.write(f"{pattern}\n")


def copy_repo_to_sandbox(repo: Path, sandbox: Path, dry_run: bool = False) -> None:
    if dry_run:
        print(f"[dry-run] git clone --local --no-hardlinks {repo} {sandbox}")
        return
    run_checked(["git", "clone", "--local", "--no-hardlinks", str(repo), str(sandbox)], timeout=240)


def bench_task_path(repo: Path) -> Path:
    return repo / ".agent-field-kit" / "bench-task.md"


def bench_log_path(repo: Path) -> Path:
    return repo / ".agent-field-kit" / "bench.log"


def default_bench_results_path(repo: Path) -> Path:
    return repo / ".agent-field-kit" / "bench-results.jsonl"


def build_agent_command(command_template: str, replacements: dict[str, str], shell: bool) -> str | list[str]:
    if shell:
        command = command_template
        for key, value in replacements.items():
            command = command.replace("{" + key + "}", shlex.quote(value))
        return command
    parts = shlex.split(command_template)
    if not parts:
        raise SystemExit("--agent-command cannot be empty")
    rendered: list[str] = []
    for part in parts:
        for key, value in replacements.items():
            part = part.replace("{" + key + "}", value)
        rendered.append(part)
    return rendered


def append_jsonl(path: Path, record: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as handle:
        json.dump(record, handle, sort_keys=True)
        handle.write("\n")


def load_jsonl(path: Path) -> list[dict]:
    if not path.exists():
        return []
    records: list[dict] = []
    for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
        if not line.strip():
            continue
        try:
            data = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(data, dict):
            records.append(data)
    return records


def append_file(source: Path, target: Path) -> None:
    if not source.exists():
        return
    target.parent.mkdir(parents=True, exist_ok=True)
    with source.open("r", encoding="utf-8", errors="replace") as src, target.open("a", encoding="utf-8") as dst:
        for line in src:
            dst.write(line)


def count_fail_cycles(events: list[dict], session: str, hook: str) -> int:
    cycles = 0
    for event in events:
        if event.get("session") != session or event.get("hook") != hook:
            continue
        if event.get("result") == "pass":
            break
        if event.get("result") == "fail":
            cycles += 1
    return cycles


def has_hook_pass(events: list[dict], session: str, hook: str) -> bool:
    return any(event.get("session") == session and event.get("hook") == hook and event.get("result") == "pass" for event in events)


def terminate_process_group(proc: subprocess.Popen) -> None:
    try:
        os.killpg(proc.pid, signal.SIGTERM)
    except ProcessLookupError:
        return
    try:
        proc.wait(timeout=5)
    except subprocess.TimeoutExpired:
        try:
            os.killpg(proc.pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        proc.wait(timeout=5)


def run_bench_agent(command: str | list[str], repo: Path, env: dict[str, str], timeout: int, log_path: Path, session: str, hook: str, shell: bool) -> tuple[int | None, bool, bool, list[dict]]:
    proc = subprocess.Popen(
        command,
        cwd=str(repo),
        env=env,
        shell=shell,
        start_new_session=True,
    )
    deadline = time.monotonic() + timeout
    timed_out = False
    saw_pass = False
    events: list[dict] = []
    while True:
        events = load_jsonl(log_path)
        saw_pass = has_hook_pass(events, session, hook)
        if saw_pass:
            break
        exit_code = proc.poll()
        if exit_code is not None:
            break
        if time.monotonic() >= deadline:
            timed_out = True
            terminate_process_group(proc)
            break
        time.sleep(0.25)
    if not timed_out and proc.poll() is None:
        try:
            proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            terminate_process_group(proc)
    events = load_jsonl(log_path)
    return proc.poll(), timed_out, saw_pass, events


def install_bench_hooks(sandbox: Path, include_envsentinel: bool, dry_run: bool = False) -> None:
    install_hooks(argparse.Namespace(repo=str(sandbox), include_envsentinel=include_envsentinel, dry_run=dry_run))


def activate_sandbox_hooks(sandbox: Path) -> None:
    run_checked(["git", "config", "core.hooksPath", ".git/hooks"], cwd=sandbox, timeout=60)


def bench_list(args: argparse.Namespace) -> int:
    for scenario in bench_scenarios().values():
        print(f"{scenario.name}\t{scenario.hook}\t{scenario.description}")
    return 0


def bench_run(args: argparse.Namespace) -> int:
    if not args.all and not args.scenario:
        raise SystemExit("Pass --scenario NAME or --all")
    if args.all and args.scenario:
        raise SystemExit("Pass either --scenario NAME or --all, not both")
    scenarios = bench_scenarios()
    selected = list(scenarios.values()) if args.all else [scenarios.get(args.scenario)]
    if any(scenario is None for scenario in selected):
        raise SystemExit(f"Unknown scenario: {args.scenario}")
    repo = Path(args.repo).expanduser().resolve()
    if not (repo / ".git").exists():
        raise SystemExit(f"Not a git repository: {repo}")
    results_path = Path(args.output).expanduser().resolve() if args.output else default_bench_results_path(repo)
    raw_log_path = results_path.parent / "bench.log"
    if args.dry_run:
        for scenario in selected:
            assert scenario is not None
            print(f"[dry-run] bench scenario {scenario.name} in isolated clone of {repo}")
            print(f"[dry-run] write task file and run agent command once: {args.agent_command}")
            print(f"[dry-run] append result to {results_path}")
        return 0
    exit_code = 0
    for scenario in selected:
        assert scenario is not None
        tmp_context = None if args.keep_sandbox else tempfile.TemporaryDirectory(prefix=f"agent-field-kit-{scenario.name}-")
        tmp = tempfile.mkdtemp(prefix=f"agent-field-kit-{scenario.name}-") if args.keep_sandbox else tmp_context.name
        try:
            sandbox = Path(tmp) / "repo"
            copy_repo_to_sandbox(repo, sandbox)
            exclude_bench_artifacts(sandbox)
            install_bench_hooks(sandbox, include_envsentinel=scenario.hook == "envsentinel")
            activate_sandbox_hooks(sandbox)
            hook_snapshot = snapshot_hooks(sandbox)
            scenario.poison(sandbox)
            if not scenario.verify_failed(sandbox):
                raise SystemExit(f"Scenario did not poison repository as expected: {scenario.name}")
            task_file = bench_task_path(sandbox)
            task_file.parent.mkdir(parents=True, exist_ok=True)
            task_text = scenario.task()
            task_file.write_text(task_text, encoding="utf-8")
            session = str(uuid.uuid4())
            replacements = {
                "task_file": str(task_file),
                "task": task_text,
                "repo": str(sandbox),
                "session": session,
                "scenario": scenario.name,
            }
            command = build_agent_command(args.agent_command, replacements, shell=args.shell)
            env = os.environ.copy()
            env.update({
                "BENCH_SESSION": session,
                "AGENT_FIELD_KIT_BENCH_TASK": str(task_file),
                "AGENT_FIELD_KIT_BENCH_SCENARIO": scenario.name,
            })
            started = time.monotonic()
            agent_exit, timed_out, saw_hook_pass, events = run_bench_agent(
                command,
                sandbox,
                env,
                args.timeout,
                bench_log_path(sandbox),
                session,
                scenario.hook,
                shell=args.shell,
            )
            elapsed = time.monotonic() - started
            resolved = scenario.verify_resolved(sandbox)
            unchanged = hooks_unchanged(sandbox, hook_snapshot)
            cycles = count_fail_cycles(events, session, scenario.hook)
            completed_recovery = cycles == 0 or saw_hook_pass
            passed = bool(resolved and unchanged and not timed_out and completed_recovery)
            append_file(bench_log_path(sandbox), raw_log_path)
            result = {
                "ts": datetime.now(timezone.utc).isoformat(),
                "session": session,
                "scenario": scenario.name,
                "hook": scenario.hook,
                "passed": passed,
                "resolved": resolved,
                "hooks_unchanged": unchanged,
                "timed_out": timed_out,
                "agent_exit_code": agent_exit,
                "saw_hook_pass": saw_hook_pass,
                "completed_recovery": completed_recovery,
                "cycles": cycles,
                "time_to_resolution_seconds": round(elapsed, 3),
                "raw_log": str(raw_log_path),
            }
            if args.keep_sandbox:
                result["sandbox"] = str(sandbox)
            append_jsonl(results_path, result)
            status = "pass" if passed else "fail"
            print(f"[{status}] {scenario.name}: cycles={cycles} seconds={result['time_to_resolution_seconds']} result={results_path}")
            if args.keep_sandbox:
                print(f"[debug] kept sandbox: {sandbox}")
            if not passed:
                exit_code = 1
        finally:
            if tmp_context is not None:
                tmp_context.cleanup()
    return exit_code


def bench_report(args: argparse.Namespace) -> int:
    results_path = Path(args.results).expanduser().resolve()
    records = load_jsonl(results_path)
    if not records:
        if args.json:
            print(json.dumps({"results": []}, indent=2, sort_keys=True))
        else:
            print(f"No benchmark results found: {results_path}")
        return 1
    total = len(records)
    passed = sum(1 for record in records if record.get("passed"))
    if args.json:
        print(json.dumps({"passed": passed, "total": total, "results": records}, indent=2, sort_keys=True))
        return 0 if passed == total else 1
    print(f"Agent Field Kit Bench Report: {passed}/{total} passed")
    for record in records:
        status = "pass" if record.get("passed") else "fail"
        cycles = record.get("cycles")
        seconds = record.get("time_to_resolution_seconds")
        details = []
        if not record.get("resolved"):
            details.append("not resolved")
        if not record.get("hooks_unchanged"):
            details.append("hooks changed")
        if record.get("timed_out"):
            details.append("timeout")
        if not record.get("completed_recovery", True):
            details.append("no recovery pass")
        suffix = f" ({', '.join(details)})" if details else ""
        print(f"[{status}] {record.get('scenario')} cycles={cycles} seconds={seconds}{suffix}")
    return 0 if passed == total else 1


def wizard(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)

    if args.non_interactive:
        missing_env = [name for name in args.require_env if not os.environ.get(name)]
        if missing_env:
            raise SystemExit("Missing required environment variables for non-interactive setup: " + ", ".join(missing_env))
        applied = apply_env_overrides(config)
        save_config(p, config)
        print(f"Saved {p.config_file}")
        if applied:
            print("Applied environment overrides: " + ", ".join(applied))
        else:
            print("No AGENT_FIELD_KIT_* config overrides were set; using existing config and defaults.")
        if not args.no_write:
            install_agent_files(p, config)
        if args.install_tools:
            install_tools(argparse.Namespace(tools=None, dry_run=False))
        return doctor(argparse.Namespace(json=False, strict=False, include_optional=False))

    print("Agent Field Kit wizard")
    print("Values are local to this machine and can be changed later.")
    config["profile_name"] = prompt("Profile name", str(config["profile_name"]))
    config["default_host"] = prompt("Default service bind host", str(config["default_host"]))
    config["service_name_style"] = prompt("Service naming style", str(config["service_name_style"]))
    config["install_bin_dir"] = prompt("User binary install directory", str(config["install_bin_dir"]))
    config["tool_source_dir"] = prompt("Downloaded tool source directory", str(config["tool_source_dir"]))
    config["portbroker_command"] = prompt("Portbroker command", str(config["portbroker_command"]))
    config["portbroker_local_source"] = prompt("Local portbroker source", str(config["portbroker_local_source"]))
    config["portbroker_repo"] = prompt("Portbroker Git repo", str(config["portbroker_repo"]))
    config["prose_hygiene_command"] = prompt("Prose hygiene command", str(config["prose_hygiene_command"]))
    config["prose_hygiene_compat_command"] = prompt("Legacy em dash scrub command", str(config["prose_hygiene_compat_command"]))
    config["prose_hygiene_local_source"] = prompt("Local prose-hygiene source", str(config["prose_hygiene_local_source"]))
    config["prose_hygiene_repo"] = prompt("Prose-hygiene Git repo", str(config["prose_hygiene_repo"]))
    config["envsentinel_command"] = prompt("EnvSentinel command", str(config["envsentinel_command"]))
    config["envsentinel_local_source"] = prompt("Local EnvSentinel source", str(config["envsentinel_local_source"]))
    config["envsentinel_repo"] = prompt("EnvSentinel Git repo", str(config["envsentinel_repo"]))
    config["engramize_local_source"] = prompt("Local Engramize source", str(config["engramize_local_source"]))
    config["engramize_repo"] = prompt("Engramize Git repo", str(config["engramize_repo"]))
    config["memory_protocol_dir"] = prompt("Memory protocol directory", str(config["memory_protocol_dir"]))
    config["github_command"] = prompt("GitHub CLI command", str(config["github_command"]))
    config["clasp_command"] = prompt("Google clasp command", str(config["clasp_command"]))
    config["clasp_auth_check_command"] = prompt("clasp auth check subcommand", str(config["clasp_auth_check_command"]))
    config["node_package_manager"] = prompt("Node package manager", str(config["node_package_manager"]))
    config["install_codex"] = prompt_bool("Install Codex instructions", bool(config["install_codex"]))
    config["install_claude"] = prompt_bool("Install Claude instructions", bool(config["install_claude"]))
    config["install_opencode"] = prompt_bool("Install OpenCode instructions", bool(config["install_opencode"]))

    save_config(p, config)
    print(f"Saved {p.config_file}")

    if not args.no_write:
        install_agent_files(p, config)

    if args.install_tools:
        install_tools(argparse.Namespace(tools=None, dry_run=False))

    return doctor(argparse.Namespace(json=False, strict=False))


def render(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    names = {
        "codex": "AGENTS.md.template",
        "claude": "CLAUDE.md.template",
        "opencode": "AGENTS.md.template",
    }
    sys.stdout.write(render_template(p, names[args.agent], config))
    return 0


def check_tool(label: str, command: str, extra_checks: Iterable[list[str]] = ()) -> bool:
    location = which(command)
    if not location:
        print(f"[missing] {label}: {command}")
        return False
    print(f"[ok] {label}: {redact(location)}")
    ok = True
    for check in extra_checks:
        code, output = run_status(check)
        status = "ok" if code == 0 else "warn"
        print(f"[{status}] {' '.join(check)}")
        if output:
            print(indent(redact(output)))
        ok = ok and code == 0
    return ok


def redact(text: str) -> str:
    home = str(Path.home())
    if home:
        text = text.replace(home, "~")
    text = re.sub(r"(?<![A-Za-z0-9._%+-])(?!(?:git|hg)@)[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}", "<email>", text)
    text = re.sub(r"account [^\s(]+", "account <github-account>", text)
    text = re.sub(r"gh[opsu]_[A-Za-z0-9_]+", "<github-token>", text)
    text = re.sub(r"[0-9]+-[A-Za-z0-9_.-]+\.apps\.googleusercontent\.com", "<google-oauth-client-id>", text)
    return text


def indent(text: str) -> str:
    return "\n".join(f"  {line}" for line in text.splitlines())


def doctor_check_result(label: str, command: str, checks: Iterable[list[str]] = ()) -> dict:
    location = which(command)
    result = {"label": label, "command": command, "path": redact(location or ""), "ok": bool(location), "checks": []}
    if not location:
        return result
    for check in checks:
        code, output = run_status(check)
        check_result = {
            "command": check,
            "returncode": code,
            "ok": code == 0,
            "output": redact(output),
        }
        result["checks"].append(check_result)
        result["ok"] = bool(result["ok"] and check_result["ok"])
    return result


def emit_doctor_json(p: Paths, config: dict, args: argparse.Namespace) -> int:
    checks: list[dict] = []
    prose_commands = [config["prose_hygiene_command"]]
    compat = config.get("prose_hygiene_compat_command")
    if compat and compat not in prose_commands:
        prose_commands.append(compat)
    prose_command = next((command for command in prose_commands if which(command)), prose_commands[0])
    checks.extend([
        doctor_check_result("prose hygiene", prose_command, [[prose_command, "--help"]] if which(prose_command) else []),
        doctor_check_result("portbroker", config["portbroker_command"], [[config["portbroker_command"], "--help"]]),
        doctor_check_result("GitHub CLI", config["github_command"], [[config["github_command"], "auth", "status"]]),
        doctor_check_result("Google clasp", config["clasp_command"], [clasp_auth_command(config)]),
    ])
    if getattr(args, "include_optional", False):
        checks.append(doctor_check_result("EnvSentinel", config["envsentinel_command"], [[config["envsentinel_command"], "--help"]]))
        engramize_source = Path(config["engramize_local_source"]).expanduser()
        engramize_target = Path(config["tool_source_dir"]).expanduser() / repo_name(str(config["engramize_repo"]))
        engramize_ok = engramize_source.exists() or engramize_target.exists()
        checks.append({
            "label": "Engramize source",
            "path": redact(str(engramize_source)),
            "fallback_path": redact(str(engramize_target)),
            "ok": engramize_ok,
            "checks": [],
        })
    config_ok = p.config_file.exists()
    overall_ok = all(bool(check["ok"]) for check in checks) and (config_ok or not args.strict)
    report = {
        "ok": overall_ok,
        "config": {"path": redact(str(p.config_file)), "exists": config_ok},
        "checks": checks,
    }
    print(json.dumps(report, indent=2))
    return 0 if overall_ok else 1


def doctor(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    if getattr(args, "json", False):
        return emit_doctor_json(p, config, args)
    prose_commands = [config["prose_hygiene_command"]]
    compat = config.get("prose_hygiene_compat_command")
    if compat and compat not in prose_commands:
        prose_commands.append(compat)
    prose_ok = any(which(command) for command in prose_commands)
    if prose_ok:
        for command in prose_commands:
            if which(command):
                prose_ok = check_tool("prose hygiene", command, [[command, "--help"]])
                break
    else:
        print(f"[missing] prose hygiene: tried {', '.join(prose_commands)}")

    results = [
        check_tool("portbroker", config["portbroker_command"], [[config["portbroker_command"], "--help"]]),
        prose_ok,
        check_tool("GitHub CLI", config["github_command"], [[config["github_command"], "auth", "status"]]),
        check_tool("Google clasp", config["clasp_command"], [clasp_auth_command(config)]),
    ]
    if getattr(args, "include_optional", False):
        results.append(check_tool("EnvSentinel", config["envsentinel_command"], [[config["envsentinel_command"], "--help"]]))
        engramize_source = Path(config["engramize_local_source"]).expanduser()
        engramize_ok = engramize_source.exists() or (Path(config["tool_source_dir"]).expanduser() / repo_name(config["engramize_repo"])).exists()
        print(f"[ok] Engramize source: {redact(str(engramize_source))}" if engramize_ok else f"[missing] Engramize source: {redact(str(engramize_source))}")
        results.append(engramize_ok)
    config_ok = p.config_file.exists()
    print(f"[ok] config: {redact(str(p.config_file))}" if config_ok else f"[warn] config not created yet: {redact(str(p.config_file))}")
    if args.strict and not config_ok:
        results.append(False)
    return 0 if all(results) else 1


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="agent-field-kit")
    parser.add_argument("--version", action="version", version=f"%(prog)s {VERSION}")
    sub = parser.add_subparsers(dest="command", required=True)

    wizard_parser = sub.add_parser("wizard", help="Prompt for local settings and install templates")
    wizard_parser.add_argument("--no-write", action="store_true", help="Save config but do not write agent files")
    wizard_parser.add_argument("--install-tools", action="store_true", help="Install configured tools after writing config")
    wizard_parser.add_argument("--non-interactive", "--ci", action="store_true", help="Use defaults, existing config, and AGENT_FIELD_KIT_* environment overrides without prompts")
    wizard_parser.add_argument("--require-env", action="append", default=[], help="In non-interactive mode, fail unless this environment variable is set; may be repeated")
    wizard_parser.set_defaults(func=wizard)

    doctor_parser = sub.add_parser("doctor", help="Check local tool and auth readiness")
    doctor_parser.add_argument("--json", action="store_true", help="Emit a machine-readable JSON report")
    doctor_parser.add_argument("--strict", action="store_true", help="Fail when config has not been written")
    doctor_parser.add_argument("--include-optional", action="store_true", help="Also check EnvSentinel and Engramize")
    doctor_parser.set_defaults(func=doctor)

    render_parser = sub.add_parser("render", help="Render an agent instruction template")
    render_parser.add_argument("--agent", choices=["codex", "claude", "opencode"], required=True)
    render_parser.set_defaults(func=render)

    tools_parser = sub.add_parser("install-tools", help="Install or update local helper tools")
    tools_parser.add_argument("tools", nargs="*", choices=["portbroker", "prose-hygiene", "envsentinel", "engramize", "clasp", "gh"])
    tools_parser.add_argument("--dry-run", action="store_true", help="Print actions without changing files")
    tools_parser.set_defaults(func=install_tools)

    hooks_parser = sub.add_parser("install-hooks", help="Install prose hygiene git hooks into a repository")
    hooks_parser.add_argument("--repo", default=".", help="Repository path")
    hooks_parser.add_argument("--include-envsentinel", action="store_true", help="Also install an EnvSentinel pre-commit hook")
    hooks_parser.add_argument("--dry-run", action="store_true", help="Print actions without changing files")
    hooks_parser.set_defaults(func=install_hooks)

    publish_parser = sub.add_parser("publish-github", help="Create or push a GitHub repository with gh")
    publish_parser.add_argument("--repo", default=".", help="Repository path")
    publish_parser.add_argument("--name", required=True, help="GitHub repository name")
    publish_parser.add_argument("--private", action="store_true", help="Create a private repository")
    publish_parser.add_argument("--push", action="store_true", help="Push after creating or when origin exists")
    publish_parser.add_argument("--branch", help="Branch to push when origin already exists")
    publish_parser.add_argument("--dry-run", action="store_true", help="Print actions without changing remote state")
    publish_parser.set_defaults(func=publish_github)

    clasp_parser = sub.add_parser("setup-clasp", help="Create or connect an Apps Script project")
    clasp_parser.add_argument("--repo", default=".", help="Project directory")
    clasp_mode = clasp_parser.add_mutually_exclusive_group()
    clasp_mode.add_argument("--script-id", help="Existing Apps Script script ID")
    clasp_parser.add_argument("--root-dir", default=".", help="clasp rootDir value")
    clasp_mode.add_argument("--create", action="store_true", help="Create a new Apps Script project with clasp")
    clasp_parser.add_argument("--title", default="Apps Script Project", help="Title when creating a project")
    clasp_parser.add_argument("--type", choices=["standalone", "docs", "sheets", "slides", "forms", "webapp", "api"])
    clasp_parser.add_argument("--push", action="store_true", help="Run clasp push -f after setup")
    clasp_parser.add_argument("--dry-run", action="store_true", help="Print actions without changing files or remote state")
    clasp_parser.set_defaults(func=setup_clasp)

    env_init_parser = sub.add_parser("init-env-contract", help="Create an EnvSentinel schema and .env.example")
    env_init_parser.add_argument("--repo", default=".", help="Repository path")
    env_init_parser.add_argument("--schema", default="envsentinel.json", help="Schema path relative to repo")
    env_init_parser.add_argument("--example", default=".env.example", help="Example env path relative to repo")
    env_init_parser.add_argument("--env", default=".env", help="Existing env file to bootstrap from")
    env_init_parser.add_argument("--from-env", action="store_true", help="Use envsentinel init when an env file exists")
    env_init_parser.add_argument("--force", action="store_true", help="Overwrite starter files")
    env_init_parser.add_argument("--dry-run", action="store_true", help="Print actions without changing files")
    env_init_parser.set_defaults(func=init_env_contract)

    env_check_parser = sub.add_parser("check-env", help="Validate env files with EnvSentinel")
    env_check_parser.add_argument("--repo", default=".", help="Repository path")
    env_check_parser.add_argument("--schema", default="envsentinel.json", help="Schema path relative to repo")
    env_check_parser.add_argument("--env", action="append", default=None, help="Env file path relative to repo; defaults to .env")
    env_check_parser.add_argument("--env-glob", action="append", help="Env glob passed through to EnvSentinel")
    env_check_parser.add_argument("--dry-run", action="store_true", help="Print actions without validating")
    env_check_parser.set_defaults(func=check_env)

    memory_parser = sub.add_parser("setup-memory", help="Install Engramize support and write a memory protocol")
    memory_parser.add_argument("--repo", default=".", help="Repository path")
    memory_parser.add_argument("--install", action="store_true", help="Install Engramize from configured source")
    memory_parser.add_argument("--dry-run", action="store_true", help="Print actions without changing files")
    memory_parser.set_defaults(func=setup_memory)

    bench_parser = sub.add_parser("bench", help="Benchmark agent recovery against injected repo failures")
    bench_sub = bench_parser.add_subparsers(dest="bench_command", required=True)

    bench_list_parser = bench_sub.add_parser("list", help="List benchmark scenarios")
    bench_list_parser.set_defaults(func=bench_list)

    bench_run_parser = bench_sub.add_parser("run", help="Run benchmark scenarios against an agent command")
    bench_mode = bench_run_parser.add_mutually_exclusive_group(required=True)
    bench_mode.add_argument("--scenario", choices=sorted(bench_scenarios()), help="Scenario to run")
    bench_mode.add_argument("--all", action="store_true", help="Run all scenarios")
    bench_run_parser.add_argument("--repo", default=".", help="Repository path to clone into an isolated sandbox")
    bench_run_parser.add_argument("--agent-command", required=True, help="Agent adapter command. Prefer a {task_file} placeholder. Parsed with shlex and run without a shell by default.")
    bench_run_parser.add_argument("--shell", action="store_true", help="Run --agent-command through a shell. Less safe; only use for shell-specific adapters.")
    bench_run_parser.add_argument("--timeout", type=int, default=300, help="Seconds to wait for the single agent invocation")
    bench_run_parser.add_argument("--output", help="Results JSONL path; defaults to REPO/.agent-field-kit/bench-results.jsonl")
    bench_run_parser.add_argument("--dry-run", action="store_true", help="Print actions without cloning, poisoning, or running the agent")
    bench_run_parser.add_argument("--keep-sandbox", action="store_true", help="Keep the temporary sandbox for debugging benchmark behavior")
    bench_run_parser.set_defaults(func=bench_run)

    bench_report_parser = bench_sub.add_parser("report", help="Summarize benchmark results JSONL")
    bench_report_parser.add_argument("--results", default=".agent-field-kit/bench-results.jsonl", help="Harness results JSONL path")
    bench_report_parser.add_argument("--json", action="store_true", help="Emit machine-readable report JSON")
    bench_report_parser.set_defaults(func=bench_report)

    args = parser.parse_args(argv)
    try:
        return args.func(args)
    except KeyboardInterrupt:
        print("Interrupted by user.", file=sys.stderr)
        return 130


if __name__ == "__main__":
    raise SystemExit(main())
