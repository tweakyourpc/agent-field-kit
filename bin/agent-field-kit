#!/usr/bin/env python3
"""Portable setup wizard for local AI coding agent environments."""

from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
from dataclasses import dataclass
from datetime import datetime, timezone
from pathlib import Path
from string import Template
from typing import Iterable


APP_NAME = "agent-field-kit"
MARKER = "Generated by Agent Field Kit"
DEFAULT_CONFIG = {
    "profile_name": "local-user",
    "default_host": "0.0.0.0",
    "service_name_style": "project-slug",
    "portbroker_command": "portbroker",
    "prose_hygiene_command": "emdash-scrub",
    "github_command": "gh",
    "clasp_command": "clasp",
    "clasp_auth_check_command": "show-authorized-user",
    "install_codex": True,
    "install_claude": True,
    "install_opencode": False,
}


@dataclass(frozen=True)
class Paths:
    root: Path
    config_dir: Path
    config_file: Path


def paths() -> Paths:
    root = Path(__file__).resolve().parents[1]
    config_home = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
    config_dir = config_home / APP_NAME
    return Paths(root=root, config_dir=config_dir, config_file=config_dir / "config.json")


def prompt(label: str, default: str) -> str:
    answer = input(f"{label} [{default}]: ").strip()
    return answer or default


def prompt_bool(label: str, default: bool) -> bool:
    suffix = "Y/n" if default else "y/N"
    answer = input(f"{label} [{suffix}]: ").strip().lower()
    if not answer:
        return default
    return answer in {"y", "yes", "true", "1"}


def load_config(p: Paths) -> dict:
    if not p.config_file.exists():
        return dict(DEFAULT_CONFIG)
    with p.config_file.open("r", encoding="utf-8") as handle:
        data = json.load(handle)
    merged = dict(DEFAULT_CONFIG)
    merged.update(data)
    return merged


def save_config(p: Paths, config: dict) -> None:
    p.config_dir.mkdir(parents=True, exist_ok=True)
    with p.config_file.open("w", encoding="utf-8") as handle:
        json.dump(config, handle, indent=2, sort_keys=True)
        handle.write("\n")


def which(command: str) -> str | None:
    return shutil.which(command)


def run_status(command: list[str]) -> tuple[int, str]:
    try:
        proc = subprocess.run(
            command,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            timeout=12,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired) as exc:
        return 127, str(exc)
    return proc.returncode, proc.stdout.strip()


def template_vars(config: dict) -> dict:
    return {
        **config,
        "generated_at": datetime.now(timezone.utc).isoformat(),
        "marker": MARKER,
    }


def render_template(p: Paths, name: str, config: dict) -> str:
    template_path = p.root / "templates" / name
    source = template_path.read_text(encoding="utf-8")
    return Template(source).safe_substitute(template_vars(config))


def write_generated(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    if path.exists():
        existing = path.read_text(encoding="utf-8", errors="replace")
        if MARKER not in existing:
            backup = path.with_suffix(path.suffix + ".bak")
            counter = 1
            while backup.exists():
                backup = path.with_suffix(path.suffix + f".bak{counter}")
                counter += 1
            path.rename(backup)
            print(f"Backed up existing file to {backup}")
    path.write_text(content, encoding="utf-8")
    print(f"Wrote {path}")


def install_agent_files(p: Paths, config: dict) -> None:
    if config.get("install_codex"):
        write_generated(Path.home() / ".codex" / "AGENTS.md", render_template(p, "AGENTS.md.template", config))
    if config.get("install_claude"):
        write_generated(Path.home() / ".claude" / "CLAUDE.md", render_template(p, "CLAUDE.md.template", config))
    if config.get("install_opencode"):
        write_generated(Path.home() / ".config" / "opencode" / "AGENTS.md", render_template(p, "AGENTS.md.template", config))


def wizard(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)

    print("Agent Field Kit wizard")
    print("Values are local to this machine and can be changed later.")
    config["profile_name"] = prompt("Profile name", str(config["profile_name"]))
    config["default_host"] = prompt("Default service bind host", str(config["default_host"]))
    config["service_name_style"] = prompt("Service naming style", str(config["service_name_style"]))
    config["portbroker_command"] = prompt("Portbroker command", str(config["portbroker_command"]))
    config["prose_hygiene_command"] = prompt("Prose hygiene command", str(config["prose_hygiene_command"]))
    config["github_command"] = prompt("GitHub CLI command", str(config["github_command"]))
    config["clasp_command"] = prompt("Google clasp command", str(config["clasp_command"]))
    config["clasp_auth_check_command"] = prompt("clasp auth check subcommand", str(config["clasp_auth_check_command"]))
    config["install_codex"] = prompt_bool("Install Codex instructions", bool(config["install_codex"]))
    config["install_claude"] = prompt_bool("Install Claude instructions", bool(config["install_claude"]))
    config["install_opencode"] = prompt_bool("Install OpenCode instructions", bool(config["install_opencode"]))

    save_config(p, config)
    print(f"Saved {p.config_file}")

    if not args.no_write:
        install_agent_files(p, config)

    return doctor(argparse.Namespace(json=False))


def render(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    names = {
        "codex": "AGENTS.md.template",
        "claude": "CLAUDE.md.template",
        "opencode": "AGENTS.md.template",
    }
    sys.stdout.write(render_template(p, names[args.agent], config))
    return 0


def check_tool(label: str, command: str, extra_checks: Iterable[list[str]] = ()) -> bool:
    location = which(command)
    if not location:
        print(f"[missing] {label}: {command}")
        return False
    print(f"[ok] {label}: {redact(location)}")
    ok = True
    for check in extra_checks:
        code, output = run_status(check)
        status = "ok" if code == 0 else "warn"
        print(f"[{status}] {' '.join(check)}")
        if output:
            print(indent(redact(output)))
        ok = ok and code == 0
    return ok


def redact(text: str) -> str:
    home = str(Path.home())
    if home:
        text = text.replace(home, "~")
    text = re.sub(r"[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,}", "<email>", text)
    text = re.sub(r"account [^\s(]+", "account <github-account>", text)
    text = re.sub(r"gh[opsu]_[A-Za-z0-9_]+", "<github-token>", text)
    text = re.sub(r"[0-9]+-[A-Za-z0-9_.-]+\.apps\.googleusercontent\.com", "<google-oauth-client-id>", text)
    return text


def indent(text: str) -> str:
    return "\n".join(f"  {line}" for line in text.splitlines())


def doctor(args: argparse.Namespace) -> int:
    p = paths()
    config = load_config(p)
    results = [
        check_tool("portbroker", config["portbroker_command"], [[config["portbroker_command"], "--help"]]),
        check_tool("prose hygiene", config["prose_hygiene_command"], [[config["prose_hygiene_command"], "--help"]]),
        check_tool("GitHub CLI", config["github_command"], [[config["github_command"], "auth", "status"]]),
        check_tool("Google clasp", config["clasp_command"], [[config["clasp_command"], config["clasp_auth_check_command"]]]),
    ]
    print(f"[ok] config: {redact(str(p.config_file))}" if p.config_file.exists() else f"[warn] config not created yet: {redact(str(p.config_file))}")
    return 0 if all(results) else 1


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="agent-field-kit")
    sub = parser.add_subparsers(dest="command", required=True)

    wizard_parser = sub.add_parser("wizard", help="Prompt for local settings and install templates")
    wizard_parser.add_argument("--no-write", action="store_true", help="Save config but do not write agent files")
    wizard_parser.set_defaults(func=wizard)

    doctor_parser = sub.add_parser("doctor", help="Check local tool and auth readiness")
    doctor_parser.add_argument("--json", action="store_true", help=argparse.SUPPRESS)
    doctor_parser.set_defaults(func=doctor)

    render_parser = sub.add_parser("render", help="Render an agent instruction template")
    render_parser.add_argument("--agent", choices=["codex", "claude", "opencode"], required=True)
    render_parser.set_defaults(func=render)

    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())

