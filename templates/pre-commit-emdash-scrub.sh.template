#!/usr/bin/env sh
# ${marker}
set -eu

prose_cmd=""
if command -v ${prose_hygiene_command} >/dev/null 2>&1; then
  prose_cmd="${prose_hygiene_command}"
elif command -v ${prose_hygiene_compat_command} >/dev/null 2>&1; then
  prose_cmd="${prose_hygiene_compat_command}"
else
  echo "No prose hygiene command found; skipping." >&2
  exit 0
fi

files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(md|txt|rst)$' || true)
if [ -z "$files" ]; then
  exit 0
fi

for file in $files; do
  if [ -f "$file" ]; then
    if ! "$prose_cmd" "$file" "$file" --json >/dev/null; then
      echo "[AGENT_DIRECTIVE: Your commit was rejected by prose hygiene while checking $file. Rewrite the staged text to remove banned stylistic markers such as em dashes, then stage the corrected file and retry the commit.]" >&2
      exit 1
    fi
    git add "$file"
  fi
done
