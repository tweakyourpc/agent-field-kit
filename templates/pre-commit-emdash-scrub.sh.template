#!/usr/bin/env sh
set -eu

if ! command -v ${prose_hygiene_command} >/dev/null 2>&1; then
  echo "${prose_hygiene_command} not found; skipping prose hygiene." >&2
  exit 0
fi

files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(md|txt|rst)$' || true)
if [ -z "$files" ]; then
  exit 0
fi

for file in $files; do
  if [ -f "$file" ]; then
    ${prose_hygiene_command} "$file" "$file" --json >/dev/null || exit 1
    git add "$file"
  fi
done

