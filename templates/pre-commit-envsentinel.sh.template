#!/usr/bin/env sh
# ${marker}
set -eu

if ! command -v ${envsentinel_command} >/dev/null 2>&1; then
  echo "${envsentinel_command} not found; skipping env validation." >&2
  exit 0
fi

if [ ! -f envsentinel.json ]; then
  exit 0
fi

if [ -f .env ]; then
  if ! ${envsentinel_command} check --schema envsentinel.json --env .env; then
    echo "[AGENT_DIRECTIVE: Your commit was rejected by EnvSentinel because .env does not satisfy envsentinel.json. Fix the missing, invalid, or extra environment variables, then retry the commit.]" >&2
    exit 1
  fi
else
  if ! ${envsentinel_command} example --schema envsentinel.json --output .env.example --force >/dev/null; then
    echo "[AGENT_DIRECTIVE: EnvSentinel could not generate .env.example from envsentinel.json. Inspect the schema, fix it, and retry the commit.]" >&2
    exit 1
  fi
  git add .env.example
fi
